# Copy this file to .env and fill your real values.
# Do NOT send your real .env or API key in Telegram groups.

# Required: Suno API key from your Suno API provider/account.
SUNO_API_KEY=PASTE_YOUR_SUNO_API_KEY_HERE

# Required by Suno API. For quick testing use a webhook.site URL.
# For production expose callback-server.mjs through Cloudflare Tunnel/ngrok/reverse proxy.
SUNO_CALLBACK_URL=https://webhook.site/PASTE_YOUR_WEBHOOK_UUID_HERE

# Optional. Keep default unless your Suno provider uses another compatible base URL.
SUNO_BASE_URL=https://api.sunoapi.org

# Optional defaults used by the plugin when the tool call does not provide values.
SUNO_DEFAULT_MODEL=V4_5ALL
SUNO_DEFAULT_NEGATIVE_TAGS=low quality, distorted vocals, clipping, noisy mix

# Optional. Used by suno_credit_status to decide if there are enough credits
# to start another song generation. The Suno credit endpoint exposes the
# current balance, but not the exact reset time.
SUNO_GENERATION_MIN_CREDITS=10
